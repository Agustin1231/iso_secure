# Supabase / PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App config
APP_NAME=ISO_SECURE
APP_VERSION=1.0.0
DEBUG=false

# API
API_PREFIX=/api/v1
